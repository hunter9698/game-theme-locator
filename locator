#!/bin/bash

# --- CONFIGURATION ---
PORT_FRONTEND=5173
PORT_BACKEND=5000
USE_TUNNEL=true
BASE_DIR=$(dirname "$(readlink -f "$0")")

# --- COLORS ---
GREEN='\033[1;32m'
BLUE='\033[1;34m'
RED='\033[1;31m'
CYAN='\033[1;36m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# --- HELP FUNCTION ---
show_help() {
    echo -e "${BLUE}NEXUS LOCATOR CLI - Help${NC}"
    echo -e "Usage: locator [options]"
    echo -e ""
    echo -e "Options:"
    echo -e "  -p, --port <num>   Set frontend port (default: 5173)"
    echo -e "  -b, --backend <num> Set backend port (default: 5000)"
    echo -e "  -n, --no-tunnel    Disable Cloudflare tunnel"
    echo -e "  -h, --help         Show this help message"
    echo -e ""
}

# --- PARSE ARGUMENTS ---
while [[ "$#" -gt 0 ]]; do
    case $1 in
        -p|--port) PORT_FRONTEND="$2"; shift ;;
        -b|--backend) PORT_BACKEND="$2"; shift ;;
        -n|--no-tunnel) USE_TUNNEL=false ;;
        -h|--help) show_help; exit 0 ;;
        *) echo "Unknown parameter passed: $1"; show_help; exit 1 ;;
    esac
    shift
done

# --- BANNER ---
clear
echo -e "${BLUE}    _   _______   _   _ ____    ${NC}"
echo -e "${BLUE}   / \  | ____\ \/ / | | / ___|   ${NC}"
echo -e "${BLUE}  / _ \ |  _|  \  /  | | \___ \   ${NC}"
echo -e "${BLUE} / ___ \| |___ /  \  | |_ ___) |  ${NC}"
echo -e "${BLUE}/_/   \_\_____/_/\_\  \__,_|____/   ${NC}"
echo -e "${CYAN}    >>> NEXUS PROTOCOL LOCATOR <<<    ${NC}"
echo -e "${BLUE}========================================${NC}"

# Check for Node.js
if ! command -v node &> /dev/null; then
    echo -e "${RED}[!] Error: Node.js is not installed.${NC}"
    exit 1
fi

# --- PORT PROTECTION ---
echo -e "${GREEN}[*] Clearing port conflicts...${NC}"
if command -v fuser &> /dev/null; then
    fuser -k "$PORT_BACKEND/tcp" &>/dev/null
    fuser -k "$PORT_FRONTEND/tcp" &>/dev/null
fi

# 1. Setup Backend
echo -e "${GREEN}[*] Initializing Nexus Backend...${NC}"
cd "$BASE_DIR/backend"
if [ ! -d "node_modules" ]; then
    echo -e "${YELLOW}    > Installing dependencies...${NC}"
    npm install &>/dev/null
fi
node index.js &
BACKEND_PID=$!

# 2. Setup Frontend
echo -e "${GREEN}[*] Initializing Nexus Frontend...${NC}"
cd "$BASE_DIR/frontend"
if [ ! -d "node_modules" ]; then
    echo -e "${YELLOW}    > Installing dependencies...${NC}"
    npm install &>/dev/null
fi
npm run dev -- --port "$PORT_FRONTEND" --host &>/dev/null &
FRONTEND_PID=$!

# 3. Cleanup on Exit
cleanup() {
    echo -e "\n${RED}[!] Powering down Nexus Protocol...${NC}"
    kill $BACKEND_PID 2>/dev/null
    kill $FRONTEND_PID 2>/dev/null
    killall cloudflared 2>/dev/null
    killall cloudflared.bin 2>/dev/null
    exit
}
trap cleanup SIGINT SIGTERM

# 4. Tunnel Generation
if [ "$USE_TUNNEL" = true ]; then
    echo -e "${GREEN}[*] Establishing Secure Tunnel...${NC}"
    cd "$BASE_DIR"
    
    # Cleanup old logs
    rm -f "$BASE_DIR/.nexus_tunnel.log"
    
    if ! command -v cloudflared &> /dev/null; then
        if [ ! -f "$BASE_DIR/cloudflared.bin" ]; then
            echo -e "${YELLOW}    > Downloading tunnel engine...${NC}"
            curl -L -s --output "$BASE_DIR/cloudflared.bin" https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64
            chmod +x "$BASE_DIR/cloudflared.bin"
        fi
        "$BASE_DIR/cloudflared.bin" tunnel --url "http://localhost:$PORT_FRONTEND" 2> "$BASE_DIR/.nexus_tunnel.log" &
    else
        cloudflared tunnel --url "http://localhost:$PORT_FRONTEND" 2> "$BASE_DIR/.nexus_tunnel.log" &
    fi

    echo -e "${YELLOW}    > Generating clean link (please wait)...${NC}"
    
    # Poll for the link
    MAX_RETRIES=20
    COUNT=0
    TUNNEL_URL=""
    while [ $COUNT -lt $MAX_RETRIES ]; do
        if [ -f "$BASE_DIR/.nexus_tunnel.log" ]; then
            TUNNEL_URL=$(grep -o "https://[a-z0-9-]\+\.trycloudflare\.com" "$BASE_DIR/.nexus_tunnel.log" | head -n1)
            if [ ! -z "$TUNNEL_URL" ]; then
                break
            fi
        fi
        sleep 1
        let COUNT++
    done
fi

# 5. Final Dashboard
echo -e "${BLUE}========================================${NC}"
echo -e "${GREEN}  DEPLOYMENT ACTIVE                     ${NC}"
echo -e "${BLUE}========================================${NC}"
echo -e "  Local App:   ${CYAN}http://localhost:$PORT_FRONTEND${NC}"
echo -e "  Local API:   ${CYAN}http://localhost:$PORT_BACKEND${NC}"

if [ ! -z "$TUNNEL_URL" ]; then
    echo -e "  Shareable Link: ${GREEN}\033[1m${TUNNEL_URL}${NC}"
fi

echo -e ""
echo -e "  ${YELLOW}Monitoring live captures below...${NC}"
echo -e "${BLUE}========================================${NC}\n"

# Prevent logs from accumulating
rm -f "$BASE_DIR/.nexus_tunnel.log"

# Keep script running and wait for children
wait
